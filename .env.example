# ─── Claude API (análise executiva de IA) ────────────────────────────────────
# Obter em: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── ERP Connector ────────────────────────────────────────────────────────────
# URL do proxy serverless que intermediará as chamadas ao ERP
# Ver documentação em: services/erpConnector.ts
VITE_ERP_PROXY_URL=https://seu-proxy.vercel.app/api/erp
# Tipo do ERP: totvs_rm | totvs_fluig | sap_b1 | generic_csv | mock
VITE_ERP_TYPE=mock
# IDs das empresas a sincronizar (separados por vírgula)
VITE_ERP_COMPANY_CODES=1,2,3,4,5,6,14,17,18,22,23

# ─── Notificações por e-mail ─────────────────────────────────────────────────
# URL do endpoint serverless para envio de e-mail (Resend, SendGrid, etc.)
# Ver exemplo de implementação em: services/notifications.ts
VITE_EMAIL_ENDPOINT=https://seu-proxy.vercel.app/api/email
VITE_EMAIL_TO=controladoria@rede-gazeta.com.br

# ─── (Legado — remover após migração completa) ────────────────────────────────
# GEMINI_API_KEY=...

# ─── Deploy Button (Vercel) ───────────────────────────────────────────────────
# Token de acesso pessoal da Vercel (vercel.com/account/tokens)
# Adicionar também nas Environment Variables do projeto na Vercel
VITE_VERCEL_DEPLOY_TOKEN=seu-token-aqui
# Slug do projeto na Vercel (padrão: dfc)
VITE_VERCEL_PROJECT_SLUG=dfc
# Slug do time na Vercel (ver na URL do painel)
VITE_VERCEL_TEAM_SLUG=fabios-projects-3395b63c
